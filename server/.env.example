# =========================================================================
# Backend Server Environment Variables Template
# Copy this file to '.env' and adjust the values for your local environment.
# =========================================================================

# Django Secret Key: Used for cryptographic signing.
# Keep this unique and secret in production! Generate a random string for local development.
SECRET_KEY=django-insecure-local-development-secret-key-change-me

# Debug Mode: Set to True for development, False for production.
DEBUG=True

# Allowed Hosts: A comma-separated list of strings representing the host/domain names that this Django site can serve.
# Example: localhost,127.0.0.1,127.0.0.1:8000
ALLOWED_HOSTS=localhost,127.0.0.1,127.0.0.1:8000

# Rate limiting for resume upload endpoint (default: 10/hour per IP)
# Format: <number>/<period> — e.g. 10/hour, 100/day, 5/min
RESUME_UPLOAD_RATE=10/hour
